# OpenRouter API key (for both Gemini and Embeddings)
OPENROUTER_API_KEY=

# LLM model to use via OpenRouter (Gemini, etc.)
LLM_MODEL=google/gemini-2.5-pro-preview-03-25

# Embedding model to use via OpenRouter (openai/text-embedding-3-small for 1536d)
EMBEDDING_MODEL=openai/text-embedding-3-small

# Upstash Vector (index must be 1536 dimensions)
UPSTASH_VECTOR_URL=
UPSTASH_VECTOR_TOKEN=

# LibreOffice binary path (for DOCX, DOC, ODT, RTF, EPUB, PPTX, PPT, ODP)
# macOS default (after: brew install --cask libreoffice):
SOFFICE_PATH=/Applications/LibreOffice.app/Contents/MacOS/soffice

# Limit concurrent documents in batch mode (Local CPU/RAM/LibreOffice limit)
# MAX_CONCURRENT_FILES=3

# Limit parallel API calls globally (OpenRouter/Gemini rate limit)
# MAX_CONCURRENT_API_CALLS=15
# Linux default:
# SOFFICE_PATH=/usr/bin/soffice